# 小合陪伴服务 —— 环境变量。复制成 .env 填真实值（.env 不入库）。

# ── 飞书自建应用 ──
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# ── MiniMax（Anthropic 兼容端点）──
MINIMAX_API_KEY=xxx
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
# 陪伴默认走 M3（百万上下文）。BOT_COMPANION_MODEL 优先，否则用 MINIMAX_MEETING_MODEL。
MINIMAX_MEETING_MODEL=MiniMax-M3
MINIMAX_MODEL=MiniMax-M2.7-highspeed
MINIMAX_SUMMARY_MODEL=MiniMax-M2.7-highspeed
# BOT_COMPANION_MODEL=MiniMax-M3      # 显式覆盖陪伴模型；M3 流式若有问题可临时降级 highspeed

# ── 陪伴白名单（逗号分隔 openId）。留空 = 放行所有私聊（仅 dev）──
XIAOHE_COMPANION_ALLOW_OPENIDS=

# ── 服务 ──
PORT=3100

# ── 可调（都有默认，一般不用设）──
# BOT_CHAT_MAX_ROUNDS=20
# BOT_THINKING_BUDGET=500
# BOT_MAX_CONCURRENT_LLM=5
# XIAOHE_STREAM_FLUSH_MS=380
